{
  "manifest_version": 3,
  "name": "Cursor Token Prices",
  "version": "1.0.0",
  "description": "Displays actual token costs on the Cursor Usage page, even when included in your plan.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://cursor.com/dashboard*",
    "https://www.cursor.com/dashboard*",
    "https://cursor.com/api/dashboard*",
    "https://www.cursor.com/api/dashboard*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://cursor.com/dashboard*",
        "https://www.cursor.com/dashboard*"
      ],
      "js": ["inject.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://cursor.com/*", "https://www.cursor.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cursor-token-prices@local.extension",
      "strict_min_version": "128.0"
    }
  }
}
